{
  "name": "praan",
  "version": "1.0.0",
  "description": "Personalized Healthy Recipe Generator - Node.js, Express, and MongoDB web app",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "test": "echo 'Run tests'"
  },
  "keywords": [
    "recipe",
    "health",
    "nutrition",
    "web-app",
    "vanilla-javascript"
  ],
  "author": "Praan Team",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^7.6.0",
    "nodemon": "^3.0.1"
  }
}
